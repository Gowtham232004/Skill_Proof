############################################################
# APPLICATION-LOCAL.YML.EXAMPLE
# 
# Copy this file to application-local.yml and fill in 
# your actual secrets. This file is NEVER committed to git.
############################################################

github:
  # Get these from: https://github.com/settings/developers
  client-id: YOUR_GITHUB_OAUTH_CLIENT_ID_HERE
  client-secret: YOUR_GITHUB_OAUTH_CLIENT_SECRET_HERE

jwt:
  # Any random 64+ character string for JWT signing
  # You can generate one: openssl rand -hex 32
  secret: YOUR_JWT_SECRET_64_CHARS_OR_MORE_HERE

spring:
  datasource:
    # Database password for local development
    password: skillproof123
